<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Arpit Bala — Official</title>

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>

<!-- Stylesheet -->
<link rel="stylesheet" href="css/style.css"/>
</head>
<body>

<!-- ══ Custom Cursor ══ -->
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- ══ Hidden YouTube Audio Player ══ -->
<div id="ytpc"><div id="yt-player"></div></div>

<!-- ══ Video Modal ══ -->
<div class="v-modal" id="videoModal">
  <div class="v-modal-inner">
    <button class="v-close" onclick="closeVideo()">✕</button>
    <iframe id="modalFrame" src="" allowfullscreen allow="autoplay; encrypted-media"></iframe>
  </div>
</div>

<!-- ══ Gallery Lightbox ══ -->
<div class="gal-lb" id="galLB">
  <button class="lb-close" onclick="closeLB()">✕</button>
  <button class="lb-nav lb-prev" onclick="navLB(-1)">&#8249;</button>
  <img class="lb-img" id="lbImg" src="" alt="Gallery Photo"/>
  <button class="lb-nav lb-next" onclick="navLB(1)">&#8250;</button>
</div>

<!-- ══ Navigation ══ -->
<nav id="navbar">
  <a class="nav-logo" onclick="showMain()">ARPIT BALA</a>
  <ul class="nav-links">
    <li><a href="#about"   onclick="showMain()">About</a></li>
    <li><a href="#songs"   onclick="showMain()">Songs</a></li>
    <li><a href="#albums"  onclick="showMain()">Albums</a></li>
    <li><a href="#videos"  onclick="showMain()">Videos</a></li>
    <li><a href="#gallery" onclick="showMain()">Gallery</a></li>
  </ul>
</nav>

<!-- ══════════════════════════════════════════
     MAIN CONTENT
══════════════════════════════════════════ -->
<div id="main-content">

  <!-- HERO -->
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-noise"></div>
    <div class="grid-overlay"></div>
    <div class="hero-content">
      <div class="hero-tag">Rapper · YouTuber · Storyteller</div>
      <h1 class="hero-name">Arpit<br/><span>Bala</span></h1>
      <p class="hero-sub">From the streets of Faridabad — reshaping Indian Hip-Hop</p>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-val">4.6M</div>
          <div class="hero-stat-lbl">Monthly Listeners</div>
        </div>
        <div>
          <div class="hero-stat-val">26+</div>
          <div class="hero-stat-lbl">Tracks Released</div>
        </div>
        <div>
          <div class="hero-stat-val">2019</div>
          <div class="hero-stat-lbl">Career Began</div>
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="about-img-wrap reveal">
      <div class="about-img-frame">
        <div class="about-img-placeholder">
          <div class="aii">AB</div>
          <div class="ain">Faridabad, Haryana</div>
        </div>
      </div>
      <div class="about-badge">
        <div class="bi">26</div>
        <div class="bs">Years</div>
      </div>
    </div>
    <div class="about-text">
      <div class="section-label reveal">The Artist</div>
      <h2 class="section-title reveal reveal-d1">Who Is <em>Arpit</em>?</h2>
      <p class="reveal reveal-d2">
        <strong>Arpit Bala</strong> (born Arpit Balabantaray, May 20, 1999) is an Indian rapper,
        lyricist and YouTube creator from <strong>Faridabad, Haryana</strong>. With 4.6M monthly
        Spotify listeners, he is one of the most compelling voices in Indian indie hip-hop.
      </p>
      <p class="reveal reveal-d3">
        Known for <strong>sharp humor, emotional depth, and desi storytelling</strong>, Arpit fuses
        ancient Indian melodies with contemporary hip-hop beats to create something wholly unique —
        from love and longing to sharp social commentary.
      </p>
      <p class="reveal reveal-d4">
        From college sketches to national stages, backed by
        <strong>Gully Gang Records &amp; Sony Music India</strong>, Arpit continues to redefine
        what Indian hip-hop can sound like.
      </p>
      <div class="about-tags reveal reveal-d4">
        <span class="about-tag">Hip-Hop</span>
        <span class="about-tag">Alt Hip-Hop</span>
        <span class="about-tag">Desi Rap</span>
        <span class="about-tag">Hinglish</span>
        <span class="about-tag">Indie</span>
        <span class="about-tag">Gully Gang</span>
      </div>
    </div>
  </section>

  <!-- SONGS -->
  <section id="songs">
    <div class="section-label reveal">Discography</div>
    <h2 class="section-title reveal reveal-d1">Popular <em>Songs</em></h2>
    <div class="songs-grid reveal reveal-d2" id="songsGrid"></div>
  </section>

  <!-- ALBUMS -->
  <section id="albums">
    <div class="section-label reveal">Catalogue</div>
    <h2 class="section-title reveal reveal-d1">Studio <em>Albums</em></h2>
    <div class="albums-grid reveal reveal-d2" id="albumsGrid"></div>
  </section>

  <!-- VIDEOS -->
  <section id="videos">
    <div class="section-label reveal">Visual</div>
    <h2 class="section-title reveal reveal-d1">Music <em>Videos</em></h2>
    <div class="videos-grid" id="videosGrid"></div>
  </section>

  <!-- GALLERY -->
  <section id="gallery">
    <div class="section-label reveal">Moments</div>
    <h2 class="section-title reveal reveal-d1">Photo <em>Gallery</em></h2>
    <div class="gal-grid reveal reveal-d2" id="galGrid"></div>
    <p class="gal-note reveal reveal-d3">
      Click any photo to enlarge &nbsp;·&nbsp;
      Follow <strong style="color:var(--gold)">@arpit_bala</strong> on Instagram
    </p>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="ft-top">
      <div class="ft-name">Arpit Bala</div>
      <div class="ft-links">
        <a class="ft-link" href="https://open.spotify.com/artist/6qtADmCOQ6a9NlpMULzJj9" target="_blank">Spotify</a>
        <a class="ft-link" href="https://music.apple.com/us/artist/arpit-bala/1564248846"  target="_blank">Apple Music</a>
        <a class="ft-link" href="https://www.jiosaavn.com/artist/arpit-bala-songs/exeBY9XlVOs_" target="_blank">JioSaavn</a>
        <a class="ft-link" href="https://www.youtube.com/@ArpitBala"   target="_blank">YouTube</a>
        <a class="ft-link" href="https://www.instagram.com/arpit_bala" target="_blank">Instagram</a>
      </div>
    </div>
    <div class="ft-bot">
      <div class="ft-copy">© 2025 Arpit Bala · All rights reserved</div>
      <div class="ft-credit">Designed &amp; Built by <span>Chirag</span></div>
    </div>
  </footer>

</div><!-- /main-content -->

<!-- ══════════════════════════════════════════
     ALBUM DETAIL PAGE (SPA — no reload)
══════════════════════════════════════════ -->
<div id="album-detail">
  <button class="back-btn" onclick="showMain()">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Back to Albums
  </button>
  <div class="det-header">
    <div class="det-art" id="detArt"></div>
    <div>
      <div class="section-label" id="detLabel">Album</div>
      <div class="det-name"      id="detName"></div>
      <div class="det-meta"      id="detMeta"></div>
    </div>
  </div>
  <div class="det-songs" id="detSongs"></div>
</div>

<!-- ══ Persistent Player Bar ══ -->
<div id="player-bar">
  <div class="p-art" id="pArt"></div>
  <div class="p-info">
    <div class="p-title"  id="pTitle">—</div>
    <div class="p-artist">Arpit Bala</div>
  </div>
  <div class="p-ctrl">
    <button class="cb"      onclick="prevSong()">&#9664;&#9664;</button>
    <button class="cb main" id="ppBtn" onclick="togglePlay()">&#9654;</button>
    <button class="cb"      onclick="nextSong()">&#9654;&#9654;</button>
  </div>
  <div class="p-prog">
    <span class="p-time" id="pCur">0:00</span>
    <div class="p-bar" id="pBar">
      <div class="p-fill" id="pFill"></div>
    </div>
    <span class="p-time" id="pTot">0:00</span>
  </div>
  <div class="p-vol">
    <span class="v-icon">🔊</span>
    <input type="range" class="v-sl" id="vSl" min="0" max="100" value="80" oninput="setVol(this.value)"/>
  </div>
  <a class="p-yt" id="pYT" href="#" target="_blank" rel="noopener">▶ YouTube</a>
</div>

<!-- ══ YouTube IFrame API (loads audio player) ══ -->
<script src="https://www.youtube.com/iframe_api"></script>

<!-- ══ Main JavaScript ══ -->
<script src="js/main.js"></script>

</body>
</html>

/* =============================================
   ARPIT BALA — Official Website Stylesheet
   Designed & Built by Chirag
   ============================================= */

/* ── CSS Variables ── */
:root {
  --gold: #e8a027;
  --gold-light: #f5c76a;
  --gold-dim: #7a4e0d;
  --bg: #080706;
  --bg2: #0f0d0b;
  --bg3: #161210;
  --surface: #1c1814;
  --surface2: #252118;
  --text: #f0e8dc;
  --text-dim: #8a7e70;
  --accent: #c94c1e;
  --accent2: #e85f2a;
}

/* ── Reset ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
  cursor: none;
}

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 2px; }

/* ── Custom Cursor ── */
.cursor {
  width: 12px; height: 12px;
  background: var(--gold);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: transform .1s;
  mix-blend-mode: difference;
}
.cursor-ring {
  width: 36px; height: 36px;
  border: 1.5px solid var(--gold);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  opacity: .6;
}

/* ── Navigation ── */
nav {
  position: fixed; top: 0; left: 0; width: 100%;
  z-index: 500;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 60px;
  background: linear-gradient(to bottom, rgba(8,7,6,.95), transparent);
  transition: all .4s;
}
nav.scrolled {
  background: rgba(8,7,6,.96);
  backdrop-filter: blur(16px);
  padding: 14px 60px;
  border-bottom: 1px solid rgba(232,160,39,.12);
}
.nav-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px; letter-spacing: 3px;
  color: var(--gold); text-decoration: none; cursor: pointer;
}
.nav-links { display: flex; gap: 36px; list-style: none; }
.nav-links a {
  font-family: 'Syne', sans-serif;
  font-size: 12px; font-weight: 600; letter-spacing: 2.5px;
  text-transform: uppercase; color: var(--text-dim);
  text-decoration: none; transition: color .3s;
  position: relative; cursor: pointer;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -3px; left: 0;
  width: 0; height: 1px; background: var(--gold); transition: width .3s;
}
.nav-links a:hover { color: var(--gold); }
.nav-links a:hover::after { width: 100%; }

/* ── Hero ── */
#hero {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 70% 50%, rgba(200,76,30,.18), transparent 65%),
    radial-gradient(ellipse 50% 80% at 20% 80%, rgba(232,160,39,.12), transparent 60%),
    radial-gradient(ellipse 100% 100% at 50% 0%, rgba(8,7,6,0) 30%, var(--bg) 100%);
  z-index: 0;
}
.hero-noise {
  position: absolute; inset: 0; opacity: .04;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px; z-index: 1; pointer-events: none;
}
.grid-overlay {
  position: absolute; inset: 0; z-index: 1;
  background-image:
    linear-gradient(rgba(232,160,39,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(232,160,39,.04) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 40%, transparent 100%);
}
.hero-content { position: relative; z-index: 2; text-align: center; padding: 0 20px; }
.hero-tag {
  display: inline-block;
  font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: 5px; text-transform: uppercase; color: var(--gold);
  border: 1px solid rgba(232,160,39,.35); padding: 7px 20px; border-radius: 100px;
  margin-bottom: 32px; animation: fadeUp .8s ease both .2s;
}
.hero-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(80px, 16vw, 200px);
  line-height: .88; letter-spacing: 4px;
  animation: fadeUp 1s ease both .4s;
}
.hero-name span {
  display: block;
  background: linear-gradient(135deg, var(--gold), var(--accent2) 60%, var(--gold-light));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hero-sub {
  font-size: 16px; font-weight: 300; font-style: italic;
  color: var(--text-dim); margin-top: 24px;
  animation: fadeUp 1s ease both .7s;
}
.hero-stats {
  display: flex; gap: 48px; justify-content: center;
  margin-top: 52px; animation: fadeUp 1s ease both .9s;
}
.hero-stat-val { font-family: 'Bebas Neue', sans-serif; font-size: 40px; color: var(--gold); line-height: 1; }
.hero-stat-lbl {
  font-family: 'Syne', sans-serif; font-size: 10px; font-weight: 600;
  letter-spacing: 2.5px; text-transform: uppercase; color: var(--text-dim); margin-top: 4px;
}
.hero-scroll {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  z-index: 2; animation: fadeIn 1s ease both 1.4s;
}
.hero-scroll span { font-family: 'Syne', sans-serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-dim); }
.scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollAnim 2s ease-in-out infinite;
}

/* ── Keyframes ── */
@keyframes scrollAnim {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  51%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
@keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes eqAnim { from { height: 4px; } to { height: 16px; } }
@keyframes rotateBadge { to { transform: rotate(360deg); } }

/* ── Section Commons ── */
section { padding: 100px 60px; }
.section-label {
  font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: 4px; text-transform: uppercase; color: var(--gold); margin-bottom: 14px;
}
.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(42px, 6vw, 80px); letter-spacing: 2px; line-height: 1; margin-bottom: 56px;
}
.section-title em { color: var(--accent2); font-style: normal; }

/* ── Reveal Animations ── */
.reveal { opacity: 0; transform: translateY(40px); transition: opacity .7s ease, transform .7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-d1 { transition-delay: .1s; }
.reveal-d2 { transition-delay: .2s; }
.reveal-d3 { transition-delay: .3s; }
.reveal-d4 { transition-delay: .4s; }

/* ── About ── */
#about {
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
  align-items: center; background: var(--bg2); position: relative; overflow: hidden;
}
#about::before {
  content: 'AB'; position: absolute; right: -40px; top: 50%; transform: translateY(-50%);
  font-family: 'Bebas Neue', sans-serif; font-size: 300px;
  color: rgba(232,160,39,.04); pointer-events: none;
}
.about-img-wrap { position: relative; z-index: 1; }
.about-img-frame {
  width: 100%; aspect-ratio: 3/4; max-width: 460px;
  background: var(--surface); border-radius: 4px; position: relative;
  overflow: hidden; border: 1px solid rgba(232,160,39,.15);
}
.about-img-frame::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(200,76,30,.3), rgba(232,160,39,.15), transparent 60%);
}
.about-img-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 16px;
}
.aii { font-family: 'Bebas Neue', sans-serif; font-size: 120px; color: rgba(232,160,39,.3); letter-spacing: 6px; line-height: 1; }
.ain { font-family: 'Syne', sans-serif; font-size: 11px; letter-spacing: 3px; color: rgba(232,160,39,.3); text-transform: uppercase; }
.about-badge {
  position: absolute; bottom: -16px; right: -16px;
  width: 100px; height: 100px; background: var(--gold); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-direction: column;
  z-index: 2; animation: rotateBadge 12s linear infinite;
}
.bi { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--bg); line-height: 1; }
.bs { font-family: 'Syne', sans-serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--bg); }
.about-text { position: relative; z-index: 1; }
.about-text p { font-size: 16px; line-height: 1.8; color: var(--text-dim); margin-bottom: 20px; }
.about-text p strong { color: var(--text); font-weight: 500; }
.about-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 32px; }
.about-tag {
  font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 600;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 7px 16px; border: 1px solid rgba(232,160,39,.25);
  border-radius: 100px; color: var(--gold); background: rgba(232,160,39,.06);
}

/* ── Songs Section ── */
#songs { background: var(--bg); }
.songs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
.song-card {
  display: flex; align-items: center; gap: 20px;
  padding: 18px 24px; background: var(--surface);
  transition: background .3s, transform .2s;
  cursor: pointer; position: relative; overflow: hidden; border-radius: 2px;
}
.song-card::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: var(--gold); transform: scaleY(0); transition: transform .3s; transform-origin: bottom;
}
.song-card:hover { background: var(--surface2); transform: translateX(4px); }
.song-card:hover::before, .song-card.playing::before { transform: scaleY(1); }
.song-card.playing { background: rgba(232,160,39,.08); }
.song-card.playing::before { background: var(--accent2); }
.song-num { font-family: 'Bebas Neue', sans-serif; font-size: 20px; color: var(--text-dim); width: 28px; flex-shrink: 0; text-align: center; transition: opacity .2s; }
.song-card:hover .song-num, .song-card.playing .song-num { opacity: 0; }
.song-play-icon { position: absolute; left: 24px; opacity: 0; transition: opacity .2s; color: var(--gold); font-size: 16px; }
.song-card:hover .song-play-icon, .song-card.playing .song-play-icon { opacity: 1; }
.s-art { width: 52px; height: 52px; flex-shrink: 0; border-radius: 3px; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 12px; letter-spacing: 1px; color: rgba(255,255,255,.65); }
.song-info { flex: 1; min-width: 0; }
.song-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color .3s; }
.song-card:hover .song-title, .song-card.playing .song-title { color: var(--gold); }
.song-meta { font-size: 12px; color: var(--text-dim); margin-top: 3px; }
.song-dur { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 600; color: var(--text-dim); flex-shrink: 0; }
.eq-bars { display: flex; align-items: flex-end; gap: 2px; height: 16px; flex-shrink: 0; opacity: 0; transition: opacity .3s; }
.song-card.playing .eq-bars { opacity: 1; }
.eq-bar { width: 3px; background: var(--gold); border-radius: 1px; animation: eqAnim .6s ease infinite alternate; }
.eq-bar:nth-child(2) { animation-delay: .15s; }
.eq-bar:nth-child(3) { animation-delay: .3s; }
.eq-bar:nth-child(4) { animation-delay: .45s; }

/* ── Player Bar ── */
#player-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 600;
  background: rgba(10,8,6,.97); backdrop-filter: blur(24px);
  border-top: 1px solid rgba(232,160,39,.2);
  padding: 0 60px; height: 76px;
  display: flex; align-items: center; gap: 24px;
  transform: translateY(100%);
  transition: transform .5s cubic-bezier(.22,1,.36,1);
}
#player-bar.visible { transform: translateY(0); }
