.p-vol { display: flex; align-items: center; gap: 8px; }
.v-icon { font-size: 14px; color: var(--text-dim); }
.v-sl { -webkit-appearance: none; appearance: none; width: 76px; height: 3px; background: rgba(255,255,255,.15); border-radius: 2px; cursor: pointer; outline: none; }
.v-sl::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; background: var(--gold); border-radius: 50%; }
.p-yt { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold-dim); text-decoration: none; padding: 6px 14px; border: 1px solid rgba(232,160,39,.2); border-radius: 100px; transition: color .2s, border-color .2s; white-space: nowrap; }
.p-yt:hover { color: var(--gold); border-color: var(--gold); }

/* Hidden YouTube Player Container */
#ytpc { position: fixed; bottom: 80px; right: 10px; width: 2px; height: 2px; opacity: .01; pointer-events: none; z-index: 599; overflow: hidden; }

/* ── Albums ── */
#albums { background: var(--bg2); }
.albums-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.album-card { position: relative; cursor: pointer; overflow: hidden; border-radius: 4px; border: 1px solid rgba(232,160,39,.08); transition: border-color .3s, transform .3s, box-shadow .3s; }
.album-card:hover { border-color: rgba(232,160,39,.45); transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,.6); }
.alb-art { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.alb-inner { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 8px; transition: transform .4s; }
.album-card:hover .alb-inner { transform: scale(1.06); }
.alb-title { font-family: 'Bebas Neue', sans-serif; font-size: 34px; letter-spacing: 2px; color: rgba(255,255,255,.22); text-align: center; padding: 0 12px; line-height: 1.1; }
.alb-ov { position: absolute; inset: 0; background: rgba(8,7,6,.55); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .3s; }
.album-card:hover .alb-ov { opacity: 1; }
.alb-btn { width: 56px; height: 56px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--bg); font-size: 22px; transform: scale(.8); transition: transform .3s; }
.album-card:hover .alb-btn { transform: scale(1); }
.alb-info { padding: 16px; background: var(--surface); }
.alb-name { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.alb-year { font-size: 12px; color: var(--text-dim); }
.alb-tracks { font-size: 11px; color: var(--gold-dim); margin-top: 4px; font-family: 'Syne', sans-serif; font-weight: 600; letter-spacing: 1px; }

/* ── Album Detail Page ── */
#album-detail { display: none; padding: 100px 60px; min-height: 100vh; background: var(--bg); }
#album-detail.active { display: block; }
.back-btn { display: inline-flex; align-items: center; gap: 10px; font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); cursor: pointer; border: none; background: none; margin-bottom: 48px; transition: color .2s; padding: 0; }
.back-btn:hover { color: var(--gold); }
.back-btn svg { transition: transform .2s; }
.back-btn:hover svg { transform: translateX(-4px); }
.det-header { display: grid; grid-template-columns: 280px 1fr; gap: 52px; align-items: end; margin-bottom: 56px; }
.det-art { width: 280px; height: 280px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 44px; letter-spacing: 3px; color: rgba(255,255,255,.25); box-shadow: 0 30px 80px rgba(0,0,0,.7); position: relative; overflow: hidden; }
.det-art::after { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,.06), transparent 60%); }
.det-name { font-family: 'Bebas Neue', sans-serif; font-size: clamp(40px, 7vw, 90px); line-height: .9; letter-spacing: 2px; margin-bottom: 16px; background: linear-gradient(135deg, var(--text), var(--gold-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.det-meta { font-size: 14px; color: var(--text-dim); display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 24px; }
.det-songs { display: flex; flex-direction: column; gap: 2px; }
.det-row { display: flex; align-items: center; gap: 20px; padding: 16px 20px; background: var(--surface); border-radius: 2px; cursor: pointer; transition: background .2s, transform .2s; position: relative; overflow: hidden; }
.det-row::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--gold); transform: scaleY(0); transition: transform .3s; transform-origin: bottom; }
.det-row:hover { background: var(--surface2); transform: translateX(4px); }
.det-row:hover::before, .det-row.playing::before { transform: scaleY(1); }
.det-row.playing { background: rgba(232,160,39,.08); }
.det-num { font-family: 'Bebas Neue', sans-serif; font-size: 18px; color: var(--text-dim); width: 24px; text-align: center; flex-shrink: 0; transition: opacity .2s; }
.det-row:hover .det-num, .det-row.playing .det-num { opacity: 0; }
.det-pi { position: absolute; left: 20px; opacity: 0; transition: opacity .2s; color: var(--gold); font-size: 16px; }
.det-row:hover .det-pi, .det-row.playing .det-pi { opacity: 1; }
.det-sname { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--text); flex: 1; transition: color .2s; }
.det-row:hover .det-sname, .det-row.playing .det-sname { color: var(--gold); }
.det-dur { font-family: 'Syne', sans-serif; font-size: 12px; color: var(--text-dim); }
.det-eq { display: flex; align-items: flex-end; gap: 2px; height: 14px; flex-shrink: 0; opacity: 0; transition: opacity .3s; }
.det-row.playing .det-eq { opacity: 1; }
.det-eq-b { width: 3px; background: var(--gold); border-radius: 1px; animation: eqAnim .6s ease infinite alternate; }
.det-eq-b:nth-child(2) { animation-delay: .15s; }
.det-eq-b:nth-child(3) { animation-delay: .3s; }

/* ── Videos ── */
#videos { background: var(--bg3); }
.videos-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 14px; }
.vid-card { position: relative; cursor: pointer; border-radius: 6px; overflow: hidden; border: 1px solid rgba(232,160,39,.08); transition: border-color .3s, transform .3s, box-shadow .3s; }
.vid-card:hover { border-color: rgba(232,160,39,.35); transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,.5); }
.vid-card.featured { grid-row: span 2; }
.vid-thumb { aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.vid-card.featured .vid-thumb { aspect-ratio: unset; height: 100%; min-height: 300px; }
.vid-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s; }
.vid-card:hover .vid-img { transform: scale(1.06); }
.vid-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%) scale(.8); width: 60px; height: 60px; background: rgba(232,160,39,.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--bg); font-size: 22px; opacity: 0; transition: opacity .3s, transform .3s; }
.vid-card:hover .vid-play { opacity: 1; transform: translate(-50%,-50%) scale(1); }
.vid-ov { position: absolute; inset: 0; background: linear-gradient(to top, rgba(8,7,6,.9), rgba(8,7,6,.1) 60%, transparent); display: flex; align-items: flex-end; padding: 18px; transition: background .3s; }
.vid-card:hover .vid-ov { background: linear-gradient(to top, rgba(8,7,6,.95) 20%, rgba(0,0,0,.35) 100%); }
.vid-dur { display: inline-block; font-family: 'Syne', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1px; color: var(--bg); background: rgba(232,160,39,.9); padding: 2px 7px; border-radius: 3px; margin-bottom: 6px; }
.vid-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.vid-card.featured .vid-title { font-size: 19px; }
.vid-views { font-size: 12px; color: var(--text-dim); }

/* ── Video Modal ── */
.v-modal { position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,.96); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .4s; backdrop-filter: blur(12px); }
.v-modal.open { opacity: 1; pointer-events: all; }
.v-modal-inner { width: 90%; max-width: 1000px; position: relative; }
.v-modal iframe { width: 100%; aspect-ratio: 16/9; border-radius: 6px; border: none; display: block; }
.v-close { position: absolute; top: -46px; right: 0; background: none; border: none; cursor: pointer; color: var(--gold); font-size: 28px; font-weight: 700; line-height: 1; transition: transform .2s; }
.v-close:hover { transform: rotate(90deg); }

/* ── Gallery ── */
#gallery { background: var(--bg2); }
.gal-grid { display: grid; grid-template-columns: repeat(5,1fr); grid-template-rows: 200px 200px; gap: 8px; }
.gal-item { overflow: hidden; border-radius: 4px; position: relative; cursor: pointer; background: var(--surface); }
.gal-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
.gal-item:nth-child(4) { grid-column: span 2; }
.gal-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s; }
.gal-item:hover .gal-img { transform: scale(1.1); }
.gal-ov { position: absolute; inset: 0; background: rgba(8,7,6,0); transition: background .3s; display: flex; align-items: center; justify-content: center; }
.gal-item:hover .gal-ov { background: rgba(8,7,6,.45); }
.gal-zoom { font-size: 26px; color: var(--gold); opacity: 0; transform: scale(.8); transition: opacity .3s, transform .3s; }
.gal-item:hover .gal-zoom { opacity: 1; transform: scale(1); }
.gal-cap { position: absolute; bottom: 0; left: 0; right: 0; padding: 10px 14px; background: linear-gradient(to top, rgba(8,7,6,.9), transparent); font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(240,232,220,.7); opacity: 0; transform: translateY(6px); transition: opacity .3s, transform .3s; }
.gal-item:hover .gal-cap { opacity: 1; transform: translateY(0); }
.gal-note { text-align: center; margin-top: 24px; font-family: 'Syne', sans-serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); }

/* ── Gallery Lightbox ── */
.gal-lb { position: fixed; inset: 0; z-index: 800; background: rgba(0,0,0,.97); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .3s; backdrop-filter: blur(12px); }
.gal-lb.open { opacity: 1; pointer-events: all; }
.lb-img { max-width: 90vw; max-height: 88vh; object-fit: contain; border-radius: 4px; box-shadow: 0 30px 100px rgba(0,0,0,.8); }
.lb-close { position: absolute; top: 24px; right: 30px; background: none; border: none; cursor: pointer; color: var(--gold); font-size: 30px; font-weight: 700; transition: transform .2s; line-height: 1; }
.lb-close:hover { transform: rotate(90deg); }
.lb-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(232,160,39,.15); border: 1px solid rgba(232,160,39,.3); border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--gold); font-size: 20px; transition: background .2s; line-height: 1; }
.lb-nav:hover { background: rgba(232,160,39,.3); }
.lb-prev { left: 20px; }
.lb-next { right: 20px; }

/* ── Footer ── */
footer { background: var(--bg); padding: 60px; border-top: 1px solid rgba(232,160,39,.1); }
.ft-top { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 28px; margin-bottom: 36px; }
.ft-name { font-family: 'Bebas Neue', sans-serif; font-size: 48px; letter-spacing: 4px; background: linear-gradient(135deg, var(--gold), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ft-links { display: flex; gap: 24px; flex-wrap: wrap; }
.ft-link { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); text-decoration: none; transition: color .2s; }
.ft-link:hover { color: var(--gold); }
.ft-bot { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; padding-top: 28px; border-top: 1px solid rgba(255,255,255,.04); }
.ft-copy { font-size: 13px; color: rgba(138,126,112,.5); }
.ft-credit { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--gold-dim); }
.ft-credit span { color: var(--gold); }

/* ── Page State ── */
#main-content.hidden { position: absolute; left: -9999px; pointer-events: none; }

/* ── Responsive ── */
@media (max-width: 1024px) {
  nav { padding: 18px 30px; }
  section, #album-detail { padding: 70px 30px; }
  #about { grid-template-columns: 1fr; gap: 40px; }
  .about-img-frame { max-width: 320px; margin: 0 auto; }
  .songs-grid { grid-template-columns: 1fr; }
  .albums-grid { grid-template-columns: repeat(2,1fr); }
  .videos-grid { grid-template-columns: 1fr; }
  .vid-card.featured { grid-row: auto; }
  .gal-grid { grid-template-columns: repeat(3,1fr); grid-template-rows: auto; }
  .gal-item:nth-child(1) { grid-column: span 2; grid-row: auto; }
  footer { padding: 40px 30px; }
  #player-bar { padding: 0 30px; }
  .det-header { grid-template-columns: 200px 1fr; gap: 32px; }
  .det-art { width: 200px; height: 200px; }
}
@media (max-width: 640px) {
  nav { padding: 16px 20px; }
  .nav-links { display: none; }
  section, #album-detail { padding: 60px 20px; }
  .hero-stats { gap: 24px; }
  .albums-grid { grid-template-columns: 1fr 1fr; }
  .gal-grid { grid-template-columns: 1fr 1fr; }
  .gal-item:nth-child(1) { grid-column: span 2; }
  footer { padding: 40px 20px; }
  #player-bar { padding: 0 16px; gap: 10px; }
  .p-prog { display: none; }
  .p-vol { display: none; }
  .det-header { grid-template-columns: 1fr; }
  .det-art { width: 100%; height: 220px; }
}

