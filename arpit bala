.p-fill::after { content: ''; position: absolute; right: -5px; top: 50%; transform: translateY(-50%); width: 12px; height: 12px; background: var(--gold-light); border-radius: 50%; opacity: 0; transition: opacity .2s; box-shadow: 0 0 8px var(--gold); }
